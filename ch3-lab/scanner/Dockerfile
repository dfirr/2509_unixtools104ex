FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
       ca-certificates \
       curl \
       iproute2 \
       iputils-ping \
       netcat-openbsd \
       nmap \
       hping3 \
       tcpdump \
    && rm -rf /var/lib/apt/lists/*

CMD ["sleep", "infinity"]
